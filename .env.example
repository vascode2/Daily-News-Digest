# Optional: Notion integration (skip if you don't use Notion)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-3-fast
# GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash
# GEMINI_YOUTUBE_FALLBACK=true
# GEMINI_YOUTUBE_FALLBACK_LIMIT=2
# NOTION_TOKEN=secret_...
# NOTION_PAGE_ID=your_32_character_notion_page_id
# NOTION_ROOT_TITLE=News Digest

# Optional: route yt-dlp + fetch through a residential/mobile proxy.
# YouTube blocks caption/timedtext downloads from datacenter IPs (e.g. GitHub
# Actions runners), which causes "자막 미제공" gaps in CI even when the same video
# has Korean captions. Setting a residential/mobile proxy restores transcripts.
# Format: http://user:pass@host:port  or  socks5://host:port
# YOUTUBE_PROXY=http://user:pass@host:port
