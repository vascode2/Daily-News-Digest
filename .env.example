# Optional: Notion integration (skip if you don't use Notion)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash
# GEMINI_YOUTUBE_FALLBACK=true
# GEMINI_YOUTUBE_FALLBACK_LIMIT=2
# NOTION_TOKEN=secret_...
# NOTION_PAGE_ID=your_32_character_notion_page_id
# NOTION_ROOT_TITLE=News Digest

# Optional Gemini transcript recovery (default ON in CI when GEMINI_API_KEY set):
# When yt-dlp can't fetch captions (datacenter IPs), Gemini watches the YouTube
# URL directly to recover real content. Disable with GEMINI_VIDEO_RECOVERY=false.
# GEMINI_VIDEO_RECOVERY=true
# GEMINI_VIDEO_RECOVERY_LIMIT=20
# Spread recovery calls + retry on 429 so more caption-less videos get recovered
# before Gemini's per-minute free-tier quota trips.
# GEMINI_RECOVERY_DELAY_MS=4000
# GEMINI_RECOVERY_MAX_RETRIES=1
# GEMINI_RECOVERY_BACKOFF_MS=15000

# Optional: route yt-dlp + fetch through a residential/mobile proxy.
# YouTube blocks caption/timedtext downloads from datacenter IPs (e.g. GitHub
# Actions runners), which causes "자막 미제공" gaps in CI even when the same video
# has Korean captions. Setting a residential/mobile proxy restores transcripts.
# Format: http://user:pass@host:port  or  socks5://host:port
# YOUTUBE_PROXY=http://user:pass@host:port

# Optional: Notion daily-section maintenance (used by `npm run notion:cleanup`).
# De-duplicates date pages and reorders so the newest digest is on top.
# REBUILD_ALL=false           # true = rebuild every output/*.md; false = only dates already in Notion
# CLEANUP_LIMIT=0             # keep only the N most recent pages (0 = no limit)
# NOTION_CREATE_DELAY_MS=400  # delay between Notion writes (rate-limit safety)
# DRY_RUN=false              # true = log actions without changing Notion
