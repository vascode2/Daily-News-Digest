{
  "name": "daily-news-digest",
  "version": "1.0.0",
  "type": "module",
  "description": "Daily Korean news and economy YouTube digest generator using Gemini",
  "scripts": {
    "collect": "node --env-file-if-exists=.env scripts/collect.js --max-per-channel 3",
    "collect:week": "node --env-file-if-exists=.env scripts/collect.js --days 7 --max-per-channel 3",
    "collect:channel": "node --env-file-if-exists=.env scripts/collect.js --channel",
    "summarize": "node --env-file-if-exists=.env scripts/summarize-claude.js",
    "summarize:gemini": "node --env-file-if-exists=.env scripts/summarize-gemini.js",
    "review": "node --env-file-if-exists=.env scripts/review.js",
    "publish": "node --env-file-if-exists=.env scripts/publish.js",
    "test": "node tests/test-pipeline.js"
  }
}
